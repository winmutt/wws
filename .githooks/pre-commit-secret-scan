#!/bin/bash
# Pre-commit hook for secret scanning
# This hook scans staged files for potential secrets before allowing commits

set -e

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "🔍 Scanning staged files for secrets..."

# Secret patterns to detect
declare -A PATTERNS
PATTERNS["AWS Access Key"]="AKIA[0-9A-Z]{16}"
PATTERNS["AWS Secret Key"]="[0-9a-zA-Z/+=]{40}"
PATTERNS["GitHub Token"]="ghp_[0-9a-zA-Z]{36}"
PATTERNS["GitHub OAuth"]="gho_[0-9a-zA-Z]{36}"
PATTERNS["GitHub App Token"]="ghu_[0-9a-zA-Z]{36}"
PATTERNS["GitHub Refresh Token"]="ghr_[0-9A-Za-z]{36}"
PATTERNS["Slack Token"]="xox[baprs]-[0-9a-zA-Z]{10,48}"
PATTERNS["Google API Key"]="AIza[0-9A-Za-z\-_]{35}"
PATTERNS["Stripe API Key"]="sk_live_[0-9a-zA-Z]{24}"
PATTERNS["Stripe Restricted Key"]="rk_live_[0-9a-zA-Z]{24}"
PATTERNS["Private Key"]="-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----"
PATTERNS["Password in Code"]="password[[:space:]]*[=:][[:space:]]*['\"][^'\"]+['\"]"
PATTERNS["API Key in Code"]="api[_-]?key[[:space:]]*[=:][[:space:]]*['\"][^'\"]+['\"]"
PATTERNS["Secret in Code"]="secret[[:space:]]*[=:][[:space:]]*['\"][^'\"]+['\"]"
PATTERNS["Bearer Token"]="Bearer [0-9a-zA-Z\-_]+"
PATTERNS["JWT Token"]="eyJ[a-zA-Z0-9\-_]+\.eyJ[a-zA-Z0-9\-_]+\.[a-zA-Z0-9\-_]+"

FOUND_SECRETS=0
FOUND_CRITICAL=0

# Check if gitleaks is available for more thorough scanning
if command -v gitleaks &> /dev/null; then
    echo "🔎 Using gitleaks for enhanced scanning..."
    
    # Scan staged files with gitleaks
    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            # Get the staged content
            STAGED_CONTENT=$(git show ":$file" 2>/dev/null || true)
            
            if [ -n "$STAGED_CONTENT" ]; then
                # Check with gitleaks
                if echo "$STAGED_CONTENT" | gitleaks detect --no-color --stdin 2>/dev/null; then
                    : # gitleaks returns 0 if no secrets found
                else
                    # gitleaks found secrets
                    echo -e "${RED}❌ Potential secrets detected in $file by gitleaks${NC}"
                    FOUND_SECRETS=$((FOUND_SECRETS + 1))
                    FOUND_CRITICAL=$((FOUND_CRITICAL + 1))
                fi
            fi
        fi
    done
fi

# Pattern-based scanning as fallback or additional check
for file in $STAGED_FILES; do
    if [ ! -f "$file" ]; then
        continue
    fi
    
    # Skip binary files
    if file "$file" | grep -q "binary"; then
        continue
    fi
    
    # Skip certain file types
    case "$file" in
        *.png|*.jpg|*.jpeg|*.gif|*.pdf|*.zip|*.tar|*.gz)
            continue
            ;;
    esac
    
    # Get staged content
    STAGED_CONTENT=$(git show ":$file" 2>/dev/null || true)
    
    if [ -z "$STAGED_CONTENT" ]; then
        continue
    fi
    
    # Check each pattern
    for pattern_name in "${!PATTERNS[@]}"; do
        pattern="${PATTERNS[$pattern_name]}"
        
        # Search for pattern in staged content
        if echo "$STAGED_CONTENT" | grep -qE "$pattern"; then
            FOUND_SECRETS=$((FOUND_SECRETS + 1))
            
            # Determine severity
            case "$pattern_name" in
                "Private Key"|"AWS Access Key"|"Stripe API Key"|"Stripe Restricted Key")
                    SEVERITY="CRITICAL"
                    FOUND_CRITICAL=$((FOUND_CRITICAL + 1))
                    COLOR="$RED"
                    ;;
                "GitHub Token"|"GitHub OAuth"|"GitHub App Token"|"GitHub Refresh Token"|"Slack Token"|"Google API Key")
                    SEVERITY="HIGH"
                    COLOR="$YELLOW"
                    ;;
                *)
                    SEVERITY="MEDIUM"
                    COLOR="$YELLOW"
                    ;;
            esac
            
            echo -e "${COLOR}⚠️  $SEVERITY: $pattern_name detected in $file${NC}"
            
            # Show the line with the secret (redacted)
            MATCH_LINE=$(echo "$STAGED_CONTENT" | grep -nE "$pattern" | head -1)
            if [ -n "$MATCH_LINE" ]; then
                LINE_NUM=$(echo "$MATCH_LINE" | cut -d: -f1)
                echo -e "${COLOR}   Line $LINE_NUM: $(echo "$MATCH_LINE" | cut -d: -f2- | sed 's/\([A-Za-z0-9]\{4\}\)[A-Za-z0-9]\{10,\}\([A-Za-z0-9]\{4\}\)/\1****\2/g')${NC}"
            fi
        fi
    done
done

# Summary
echo ""
if [ $FOUND_SECRETS -gt 0 ]; then
    echo -e "${RED}========================================${NC}"
    echo -e "${RED}❌ Commit blocked: Found $FOUND_SECRETS potential secret(s)${NC}"
    if [ $FOUND_CRITICAL -gt 0 ]; then
        echo -e "${RED}   $FOUND_CRITICAL critical severity issue(s)${NC}"
    fi
    echo -e "${RED}========================================${NC}"
    echo ""
    echo "📋 To fix these issues:"
    echo "   1. Remove the secrets from your code"
    echo "   2. Use environment variables or a secrets manager"
    echo "   3. If you've already committed secrets, rotate them immediately!"
    echo ""
    echo "💡 To bypass this check (NOT RECOMMENDED):"
    echo "   git commit --no-verify"
    echo ""
    exit 1
fi

echo -e "${GREEN}✅ No secrets detected. Safe to commit.${NC}"
exit 0