# GitHub OAuth Application Credentials
# Get these from https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# OAuth Callback URL (adjust for your deployment)
GITHUB_CALLBACK_URL=http://localhost:8080/oauth/callback

# CORS Origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API Configuration
API_URL=http://localhost:8080

# Workspace Defaults
WORKSPACE_IDLE_TIMEOUT_HOURS=6
WORKSPACE_DEFAULT_STORAGE_GB=20
WORKSPACE_DEFAULT_CPU=2
WORKSPACE_DEFAULT_MEMORY_GB=4
